---
import Header from '../components/Header.astro';
---
<html>
<head>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
  <Header />
<main class="mx-auto max-w-6xl px-4 py-8 md:px-8">
  <div class="overflow-hidden rounded-2xl shadow-xl md:flex">
    <aside class="w-full bg-blue-700 p-8 text-white md:w-1/3">
      <h2 class="mb-3 text-3xl font-extrabold">Let's get in touch</h2>
      <p class="mb-8 text-white/90">We're open for any suggestion or just to have a chat</p>

      <div class="space-y-6">
        <div class="flex items-center gap-3">
          <i class="bi bi-geo-alt inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/30" aria-hidden="true"></i>
          <div class="text-sm">Gen. Santos Ave., Upper Bicutan, Taguig City, Metro Manila, 1631, Philippines</div>
        </div>
        <div class="flex items-center gap-3">
          <i class="bi bi-telephone inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/30" aria-hidden="true"></i>
          <div class="text-sm">Phone: + 1235 2355 98</div>
        </div>
        <div class="flex items-center gap-3">
          <i class="bi bi-envelope inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/30" aria-hidden="true"></i>
          <div class="text-sm">Email: info@yoursite.com</div>
        </div>
        <div class="flex items-center gap-3">
          <i class="bi bi-globe inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/30" aria-hidden="true"></i>
          <div class="text-sm">Website: yoursite.com</div>
        </div>
      </div>
    </aside>

    <section class="flex-1 bg-white p-8">
      <h2 class="mb-6 text-3xl font-extrabold text-slate-900">Get in touch</h2>
      <form action="#" method="post" class="grid grid-cols-1 gap-5 md:grid-cols-2">
          <div class="flex flex-col gap-2">
            <label for="fullname" class="text-xs font-bold uppercase tracking-wider text-slate-700">Full name</label>
            <input id="fullname" name="fullname" type="text" placeholder="Name" class="rounded-md border border-slate-300 px-3 py-2 outline-none ring-blue-300 focus:ring">
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="text-xs font-bold uppercase tracking-wider text-slate-700">Email address</label>
            <input id="email" name="email" type="email" placeholder="Email" class="rounded-md border border-slate-300 px-3 py-2 outline-none ring-blue-300 focus:ring">
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label for="subject" class="text-xs font-bold uppercase tracking-wider text-slate-700">Subject</label>
            <input id="subject" name="subject" type="text" placeholder="Subject" class="rounded-md border border-slate-300 px-3 py-2 outline-none ring-blue-300 focus:ring">
          </div>

          <div class="flex flex-col gap-2 md:col-span-2">
            <label for="message" class="text-xs font-bold uppercase tracking-wider text-slate-700">Message</label>
            <textarea id="message" name="message" placeholder="Message" class="min-h-28 rounded-md border border-slate-300 px-3 py-2 outline-none ring-blue-300 focus:ring"></textarea>
          </div>

          <div class="md:col-span-2">
            <button class="inline-flex rounded-md bg-blue-700 px-5 py-3 font-semibold text-white shadow-md hover:bg-blue-800" type="submit">Send Message</button>
          </div>
      </form>
    </section>
  </div>
</main>

  </body>
  
</html>