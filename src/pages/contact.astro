---
import '../styles/global.css';
import '../styles/contact.css';
import Header from '../components/Header.astro';
---
<html>
<head>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
  <body>
  <Header />
<main class="contact-section">
  <div class="contact-container">
    <aside class="contact-left">
      <h2>Let's get in touch</h2>
      <p class="lead">We're open for any suggestion or just to have a chat</p>

      <div class="contact-info">
        <div class="info-item">
          <i class="bi bi-geo-alt icon" aria-hidden="true"></i>
          <div class="info-text">Gen. Santos Ave., Upper Bicutan, Taguig City, Metro Manila, 1631, Philippines</div>
        </div>
        <div class="info-item">
          <i class="bi bi-telephone icon" aria-hidden="true"></i>
          <div class="info-text">Phone: + 1235 2355 98</div>
        </div>
        <div class="info-item">
          <i class="bi bi-envelope icon" aria-hidden="true"></i>
          <div class="info-text">Email: info@yoursite.com</div>
        </div>
        <div class="info-item">
          <i class="bi bi-globe icon" aria-hidden="true"></i>
          <div class="info-text">Website: yoursite.com</div>
        </div>
      </div>
    </aside>

    <section class="contact-right">
      <h2>Get in touch</h2>
      <form class="contact-form" action="#" method="post">
        <div class="form-grid">
          <div class="form-group">
            <label for="fullname">Full name</label>
            <input id="fullname" name="fullname" type="text" placeholder="Name">
          </div>
          <div class="form-group">
            <label for="email">Email address</label>
            <input id="email" name="email" type="email" placeholder="Email">
          </div>

          <div class="form-group full">
            <label for="subject">Subject</label>
            <input id="subject" name="subject" type="text" placeholder="Subject">
          </div>

          <div class="form-group full">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Message"></textarea>
          </div>

          <div class="form-group full">
            <button class="send-btn" type="submit">Send Message</button>
          </div>
        </div>
      </form>
    </section>
  </div>
</main>

  </body>
  
</html>