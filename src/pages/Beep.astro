---
import Header from '../components/Header.astro';
import beepData from '../data/beepCodes.json';

const badgeClasses = {
  ram: 'bg-amber-100 text-amber-800',
  cpu: 'bg-emerald-100 text-emerald-800',
  gpu: 'bg-blue-100 text-blue-800',
  mb: 'bg-rose-100 text-rose-800',
  bios: 'bg-violet-100 text-violet-800',
  ok: 'bg-emerald-100 text-emerald-800'
};
---
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="/STII.png" />
  <title>Motherboard Beep Codes - DOST STII</title>
</head>
<body class="min-h-screen bg-slate-100 text-slate-800">
  <Header />

  <main class="mx-auto max-w-7xl px-4 py-8 md:px-8">
    <section class="mb-8 rounded-2xl bg-gradient-to-r from-slate-800 to-blue-700 p-6 text-white shadow-xl">
      <h1 class="text-3xl font-extrabold tracking-tight">Motherboard Beep Code Reference</h1>
      <p class="mt-2 text-white/85">Diagnose hardware failures using POST (Power-On Self Test) audio signals.</p>
    </section>

    <section class="mb-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="inline-block border-b-4 border-blue-600 pb-1 text-2xl font-extrabold">What Are BIOS Beep Codes?</h2>
      <p class="mt-4 leading-7 text-slate-700">When you turn on a computer, the motherboard performs POST (Power-On Self Test) to check essential hardware. If there is a fault before video output is available, the motherboard can emit a series of beep patterns through the speaker.</p>
      <p class="mt-3 font-semibold text-red-600">These sounds follow known patterns and can quickly point to RAM, CPU, GPU, motherboard, or BIOS-related problems.</p>
      <div class="mt-4 rounded-r-lg border-l-4 border-blue-600 bg-blue-50 p-4 text-sm text-slate-700">
        <strong>Important:</strong> Beep codes are often the first and only diagnostics when there is no screen output.
      </div>
    </section>

    <section class="mb-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="inline-block border-b-4 border-blue-600 pb-1 text-2xl font-extrabold">Beep Code Reference Tables</h2>
      <p class="mt-3 text-slate-700">Select your BIOS manufacturer. If unsure, check your motherboard manual or startup splash screen.</p>

      <div class="mt-4">
        <select class="beep-select w-full rounded-lg border-2 border-blue-600 bg-blue-50 px-4 py-2 font-semibold text-slate-800" onchange="showTab(this.value)">
          {beepData.map(brand => (
            <option value={brand.id}>{brand.label}</option>
          ))}
        </select>
      </div>

      <div class="mt-4 space-y-4">
        {beepData.map((brand, i) => (
          <div id={`tab-${brand.id}`} class={`beep-tab-content ${i === 0 ? '' : 'hidden'}`}>
            <div class="rounded-t-lg border border-slate-200 bg-slate-50 px-4 py-3 text-sm">
              <strong>{brand.title}</strong>
              <p class="mt-1 text-slate-600">{brand.note}</p>
            </div>
            <div class="overflow-x-auto rounded-b-lg border border-t-0 border-slate-200">
              <table class="min-w-full border-collapse text-left text-sm">
                <thead>
                  <tr class="bg-slate-800 text-white">
                    <th class="px-4 py-2">{brand.codeHeader}</th>
                    <th class="px-4 py-2">Description</th>
                    <th class="px-4 py-2">Component</th>
                    <th class="px-4 py-2">BIOS Key</th>
                  </tr>
                </thead>
                <tbody>
                  {brand.codes.map(c => (
                    <tr class="border-b border-slate-200 even:bg-slate-50">
                      <td class="whitespace-nowrap px-4 py-2 font-mono font-bold text-slate-800">{c.code}</td>
                      <td class="px-4 py-2">{c.desc}</td>
                      <td class="px-4 py-2">
                        <span class={`rounded-full px-3 py-1 text-xs font-bold uppercase ${badgeClasses[c.badge] || 'bg-slate-100 text-slate-700'}`}>
                          {c.component}
                        </span>
                      </td>
                      <td class="px-4 py-2">
                        <span class="rounded border border-slate-300 bg-slate-100 px-2 py-1 font-mono text-xs">{brand.biosKey}</span>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="inline-block border-b-4 border-blue-600 pb-1 text-2xl font-extrabold">Troubleshooting Tips</h2>
      <div class="mt-4 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="mb-2 text-2xl font-black text-blue-700">01</div>
          <h4 class="font-bold">Identify your BIOS</h4>
          <p class="mt-1 text-sm text-slate-600">Check startup splash screen or motherboard documentation.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="mb-2 text-2xl font-black text-blue-700">02</div>
          <h4 class="font-bold">Count beeps carefully</h4>
          <p class="mt-1 text-sm text-slate-600">Short and long beep patterns matter. Phoenix codes include grouped pauses.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="mb-2 text-2xl font-black text-blue-700">03</div>
          <h4 class="font-bold">Reseat hardware</h4>
          <p class="mt-1 text-sm text-slate-600">For RAM and GPU errors, reseat components before replacing them.</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="mb-2 text-2xl font-black text-blue-700">04</div>
          <h4 class="font-bold">Check power and cables</h4>
          <p class="mt-1 text-sm text-slate-600">Loose power connectors can trigger POST failures.</p>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    function showTab(name) {
      document.querySelectorAll('.beep-tab-content').forEach((el) => el.classList.add('hidden'));
      const tab = document.getElementById('tab-' + name);
      if (tab) tab.classList.remove('hidden');
      const sel = document.querySelector('.beep-select');
      if (sel) sel.value = name;
      localStorage.setItem('beep-selected', name);
    }

    (function() {
      const saved = localStorage.getItem('beep-selected');
      if (saved) showTab(saved);
    })();
  </script>
</body>
</html>
