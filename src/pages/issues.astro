---
import Header from '../components/Header.astro';
import issues from '../data/issues.json';
const issuesJson = JSON.stringify(issues).replace(/</g, '\\u003c');
---

<html>
<head>
</head>
  <body class="min-h-screen bg-slate-100 text-slate-900">
  <Header />
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-8">
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center">
      <label for="productFilter" class="text-xs font-bold uppercase tracking-wider text-slate-700">Filter by product</label>
      <div class="relative inline-block max-w-xs">
        <select id="productFilter" aria-label="Filter issues by product" class="w-full rounded-xl border border-slate-300 bg-white px-4 py-2 pr-10 text-sm outline-none ring-blue-300 focus:ring">
        <option value="">All Products</option>
        {
          Array.from(new Set(issues.map(item => item.product))).map(product => (
            <option value={product?.toString().toLowerCase().trim() ?? ''}>{product}</option>
          ))
        }
      </select>
      </div>
    </div>
  <div class="overflow-x-auto rounded-xl bg-white shadow-lg">
    <table id="issuesTable" class="min-w-full border-collapse text-left text-sm">
      <thead>
        <tr class="bg-slate-800 text-white">
          <th class="px-4 py-3">Product Name</th>
          <th class="px-4 py-3">Known Issues</th>
          <th class="px-4 py-3">Solution</th>
          <th class="px-4 py-3">Sources</th>
        </tr>
      </thead>
      <tbody>
        <!-- Server-rendered rows for no-JS and initial view -->
        {
          issues.map(item => (
            <tr class="odd:bg-white even:bg-slate-50">
              <td class="px-4 py-3">{item.product}</td>
              <td class="px-4 py-3">{item.issue}</td>
              <td class="px-4 py-3">{item.solution}</td>
              <td class="px-4 py-3"><a href={item.source} target="_blank" class="font-semibold text-blue-700 hover:text-blue-900">View Discussion</a></td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

<script type="text/javascript" is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    let issues = [];
    (function() {
      const el = document.getElementById('astro-issues-data');
      const raw = el ? (el.getAttribute && el.getAttribute('data-json') || el.textContent || el.innerText || '') : '';
      function tryParse(s) {
        if (!s) return null;
        try {
          return JSON.parse(s);
        } catch (e) {
          return null;
        }
      }
      // 1) try direct parse
      issues = tryParse(raw) || [];
      if (!issues.length) {
        // 2) try to extract a JSON substring starting at first '[' or '{' and ending at matching bracket
        const startIdx = Math.max(raw.indexOf('['), raw.indexOf('{'));
        if (startIdx >= 0) {
          const openChar = raw[startIdx];
          const closeChar = openChar === '[' ? ']' : '}';
          let depth = 0;
          let endIdx = -1;
          for (let i = startIdx; i < raw.length; i++) {
            const ch = raw[i];
            if (ch === openChar) depth++;
            else if (ch === closeChar) depth--;
            if (depth === 0) { endIdx = i; break; }
          }
          if (endIdx > startIdx) {
            const substr = raw.slice(startIdx, endIdx + 1);
            const parsed = tryParse(substr);
            if (parsed) issues = parsed;
          }
        }
      }
      if (!issues || issues.length === 0) {
        try {
          issues = JSON.parse('[]');
        } catch (e) {
          issues = [];
        }
      }
      if (!issues || !issues.length) {
        console.warn('issues data is empty after parsing. Raw data logged below for inspection.');
        console.log('Raw issues data (first 200 chars):', raw && raw.slice ? raw.slice(0,200) : raw);
      }
    })();
    const table = document.getElementById('issuesTable');
    const tbody = table ? table.querySelector('tbody') : null;
    const productFilter = document.getElementById('productFilter');
    function renderRows(filter = '') {
      if (!tbody) return;
      console.log('renderRows called with filter:', filter);
      while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
      const f = (filter || '').toString().trim().toLowerCase();
      const filtered = issues.filter(item => {
        if (!f) return true;
        const p = (item.product || '').toString().toLowerCase().trim();
        return p === f;
      });
      console.log('filtered products:', filtered.map(i => i.product));
      if (filtered.length === 0) {
        const row = document.createElement('tr');
        row.innerHTML = `<td colspan='4' class='px-4 py-6 text-center'>No issues found for this product.</td>`;
        tbody.appendChild(row);
        return;
      }
      filtered.forEach(item => {
        const row = document.createElement('tr');
        row.className = 'odd:bg-white even:bg-slate-50';
        row.innerHTML = `
          <td class="px-4 py-3">${item.product}</td>
          <td class="px-4 py-3">${item.issue}</td>
          <td class="px-4 py-3">${item.solution}</td>
          <td class="px-4 py-3"><a href="${item.source}" target="_blank" class="font-semibold text-blue-700 hover:text-blue-900">View Discussion</a></td>
        `;
        tbody.appendChild(row);
      });
    }
    renderRows();
    productFilter.addEventListener('change', e => renderRows(e.target.value));
  });
</script>
<script type="application/json" id="astro-issues-data" is:inline data-json={issuesJson}></script>

    </body>
  
</html>